# See ENVIRONMENTS.md — there is currently only ONE Supabase project
# (production). Until a staging project exists, local dev connects to
# production data. The app will print a console warning in dev mode if it
# detects the known production project ref.
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Optional — once a separate staging Supabase project exists, set these to
# point local development at it instead of production. (Not yet wired into
# the client automatically; see ENVIRONMENTS.md for the swap-over steps.)
# VITE_STAGING_SUPABASE_URL="https://your-staging-ref.supabase.co"
# VITE_STAGING_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
